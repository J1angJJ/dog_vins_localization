<launch>
  <!-- RViz-only dashboard. Use this when the localization main chain is already running. -->
  <arg name="rviz_config" default="$(find dog_vins_bringup)/config/dog_vins_localization.rviz"/>
  <arg name="publish_world_odom_tf" default="false"/>
  <arg name="publish_camera_base_tf" default="false"/>

  <node if="$(arg publish_camera_base_tf)"
        pkg="tf"
        type="static_transform_publisher"
        name="dog_vins_rviz_base_link_to_camera_link_tf"
        args="0.2 0.0 0.0 -0.1635689211 0.0 0.0 0.9865319093 base_link camera_link 100"/>

  <node if="$(arg publish_world_odom_tf)"
        pkg="tf"
        type="static_transform_publisher"
        name="dog_vins_rviz_world_to_odom_tf"
        args="0 0 0 0 0 0 world odom 100"/>

  <node pkg="rviz"
        type="rviz"
        name="dog_vins_rviz"
        args="-d $(arg rviz_config)"/>
</launch>
